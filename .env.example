# AI Provider 配置
# 复制此文件为 .env 并填入你的 API Key

# Provider 选择（可选，默认: moonshot）
# 可选值: moonshot, deepseek
# AI_PROVIDER=moonshot

# Moonshot API Key
# 获取方式：https://platform.moonshot.cn/
MOONSHOT_API_KEY=your_moonshot_api_key_here

# DeepSeek API Key
# 获取方式：https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# DeepSeek 模型选择（可选，默认: deepseek-v4-pro）
# - deepseek-v4-pro:  性能更强，适合复杂题目
# - deepseek-v4-flash: 速度更快，成本更低
# DEEPSEEK_MODEL=deepseek-v4-pro

# DeepSeek 思考模式开关（可选，默认: enabled）
# - enabled:  开启思考模式（准确率更高，token 消耗更大）
# - disabled: 关闭思考模式（速度更快，成本更低）
# DEEPSEEK_THINKING=enabled

# 是否生成解题报告（可选，默认: false）
# true: 生成 SOLUTION_REPORT_{problem_id}.md 解题报告（用于 CI 每日一题 PR）
# false: 不生成报告（默认，节省 API token）
# 也可通过命令行参数 --report 临时开启
# AI_SOLVER_GENERATE_REPORT=false

# 是否强制尝试新解法（可选，默认: false）
# 当题目文件已存在时：
# true: 即使文件存在也尝试提供新的解法思路（会覆盖原有文件）
# false: 如果文件已存在则跳过（默认行为）
# AI_SOLVER_FORCE_NEW_SOLUTION=false

# 实验指标落盘目录（可选，默认: 不落盘）
# 设置后每次解题结束会写 metrics_p{problem_id}_{provider}_{model}_{think}.json
# 供 run_experiment.sh 汇总成 CSV 对比
# AI_SOLVER_METRICS_DIR=experiment_logs/metrics

# 是否启用 LeetCode 在线提交验证（可选，默认: true）
# true: AI 解题完成后会提交到 LeetCode 判题（需要配置 LEETCODE_COOKIE）。
#       本地测试用例可能不全，LeetCode 真实判题是更可信的正确性信号。
# false: 跳过在线提交，只进行本地编译和测试。
# 也可用命令行参数 --no-leetcode / --require-leetcode 一次性覆盖。
# LEETCODE_SUBMIT_ENABLED=true

# LeetCode Cookie
LEETCODE_COOKIE='csrftoken=xxx; LEETCODE_SESSION=xxx'

# Cookie 失效告警 webhook（可选）
LEETCODE_COOKIE_ALERT_WEBHOOK_URL='https://example.com/webhook'

# 可选：cookie update 默认目标仓库（owner/repo）
# GITHUB_REPO=owner/repo
